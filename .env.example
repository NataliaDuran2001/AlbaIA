# ============================================================================
# AlbaIA — environment template
# ----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in the real values:
#     cp .env.example .env.local
#
# `.env.local` is gitignored (see .gitignore → `.env*.local`) and must NEVER
# be committed. This template carries only variable NAMES, no secrets.
# ============================================================================

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — treat as highly sensitive.
SUPABASE_SERVICE_ROLE_KEY=

# --- Field encryption (lib/crypto/encryption.ts) ---
# 32-byte (256-bit) key for AES-256-GCM. Generate with:
#     openssl rand -base64 32
# Rotating it makes previously encrypted values unreadable — back it up.
DATA_ENCRYPTION_KEY=

# --- AI provider (OpenAI-compatible Chat Completions) ---
# Powers the in-app assistant (chatbot) and the AI roadmap analysis.
# Any provider with an OpenAI-compatible endpoint works — set the base URL,
# key, and model to match. Without AI_API_KEY the app falls back to
# deterministic logic (roadmap rows get generated_by='fallback').
#
# Fireworks (default):  https://api.fireworks.ai/inference/v1
#   AI_MODEL example:   accounts/fireworks/models/llama-v3p3-70b-instruct
# OpenRouter:           https://openrouter.ai/api/v1
#   AI_MODEL example:   openai/gpt-4o
AI_API_KEY=
AI_BASE_URL=https://api.fireworks.ai/inference/v1
AI_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
# Optional attribution (shown in some providers' dashboards, e.g. OpenRouter):
AI_SITE_URL=http://localhost:3000
AI_SITE_NAME=AlbaIA
